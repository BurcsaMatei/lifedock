{
  "name": "lifedock",
  "version": "0.1.0",
  "private": true,
  "description": "LifeDock - personal, student and company admin hub built with Next.js, TypeScript and Vanilla Extract.",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs --fix",
    "typecheck": "tsc --noEmit",
    "check:env": "node ./scripts/verify-env.mjs",
    "check:imports": "node ./scripts/check-relative-imports.mjs",
    "check:structure": "node ./scripts/verify-structure.mjs",
    "check:types": "node ./scripts/check-strict-types.mjs",
    "check": "npm run lint && npm run typecheck && npm run check:imports && npm run check:structure && npm run check:types",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx ./prisma/seed.ts",
    "db:studio": "prisma studio",
    "tree": "powershell -ExecutionPolicy Bypass -File ./scripts/project-tree.ps1",
    "release": "powershell -ExecutionPolicy Bypass -File ./scripts/release.ps1",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "dotenv": "^17.3.1",
    "next": "16.1.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "web-push": "^3.6.7",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^22.15.32",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/web-push": "^3.6.4",
    "@vanilla-extract/css": "^1.17.4",
    "@vanilla-extract/next-plugin": "2.4.17",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.29.0",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.4.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
