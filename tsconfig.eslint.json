{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "scripts/**/*.ts",
    "scripts/**/*.tsx",
    "scripts/**/*.js",
    "scripts/**/*.mjs",
    "scripts/**/*.cjs",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "*.ts",
    "*.tsx",
    "*.js",
    "*.mjs",
    "*.cjs"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "coverage",
    "playwright-report",
    "test-results"
  ]
}